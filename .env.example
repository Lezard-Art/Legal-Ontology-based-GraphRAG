# Copy to .env. Both DB URLs can point at SQLite for local dev/tests.
DATABASE_URL_CORPUS=postgresql+psycopg2://corpus:corpus@localhost:5433/corpus
DATABASE_URL_PARSED=postgresql+psycopg2://parsed:parsed@localhost:5434/parsed
BLOB_STORE_ROOT=./data/raw
LOG_LEVEL=INFO

# --- API keys for data sources ---
# Sources without a key here will still appear in the DB (enabled=False) but
# will raise a RuntimeError if a fetch is triggered.

# Congress.gov — register at https://api.congress.gov/sign-up/
CONGRESS_API_KEY=

# CourtListener — register at https://www.courtlistener.com/register/
COURTLISTENER_API_KEY=

# NY Senate Open Legislation — register at https://legislation.nysenate.gov/register
NY_SENATE_API_KEY=
