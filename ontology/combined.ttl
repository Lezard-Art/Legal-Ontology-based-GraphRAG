@prefix :     <urn:normgraph:onto#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

# ============================================================
# Combined Normative Ontology — Integration Layer
#
# Imports the four vocabulary layers and adds the integration
# classes that bundle them:
#   - NormativeExtraction (parser output object)
#   - JudicialInterpretation (court-created legal positions)
#   - CanonicalAgent + AliasResolutionRule (entity resolution)
#   - AuthoritativeInterpretation (jurisdiction-scoped authority)
#   - Ambiguity + RelatedProvision (quality and cross-doc links)
#
# All four layer ontologies use the same namespace
# <urn:normgraph:onto#>, so importing them here merges their
# vocabularies into a single graph without prefix collisions.
#
# Schema authority: docs/ontology-schema.md §§7-9
# ============================================================

<urn:normgraph:onto/combined>
    a owl:Ontology ;
    rdfs:label "Combined Normative Ontology" ;
    rdfs:comment "Integration layer importing UFO-L, LegalRuleML, Domain, and USLM vocabularies. Adds NormativeExtraction and entity-resolution classes." ;
    owl:imports <urn:normgraph:onto/ufo-l> ;
    owl:imports <urn:normgraph:onto/legalruleml> ;
    owl:imports <urn:normgraph:onto/domain> ;
    owl:imports <urn:normgraph:onto/uslm> .

# ============================================================
# Integration Classes
# ============================================================

# ---- NormativeExtraction ----
# The complete structured representation of a single statutory
# provision produced by the parser. Bundles all four layers.

:NormativeExtraction
    a owl:Class ;
    rdfs:label "NormativeExtraction" ;
    rdfs:comment "The parser's complete output for a single statutory provision: source info, normative rules, legal positions, domain entities, interpretations, and quality metadata." .

# ---- JudicialInterpretation ----
# Court decisions as first-class entities that can create,
# modify, or override statutory legal positions.

:JudicialInterpretation
    a owl:Class ;
    rdfs:label "JudicialInterpretation" ;
    rdfs:comment "A court decision that interprets a statutory provision, potentially creating or modifying legal positions beyond the plain text." .

# ---- CanonicalAgent ----
# Entity-resolution registry: maps aliases to canonical IRIs.

:CanonicalAgent
    a owl:Class ;
    rdfs:label "CanonicalAgent" ;
    rdfs:comment "Registry entry for an agent that may be referenced by many aliases across statutes. Provides the canonical IRI and cross-references." .

# ---- AliasResolutionRule ----
# Rules for resolving in-text aliases to canonical agents.

:AliasResolutionRule
    a owl:Class ;
    rdfs:label "AliasResolutionRule" ;
    rdfs:comment "A rule that maps an alias pattern (e.g., 'the Secretary' within a Labor chapter) to a canonical agent." .

# ---- AuthoritativeInterpretation ----
# Tracks which interpretation is controlling per jurisdiction.

:AuthoritativeInterpretation
    a owl:Class ;
    rdfs:label "AuthoritativeInterpretation" ;
    rdfs:comment "Identifies the currently controlling interpretation of a provision for a specific jurisdiction and authority level." .

# ---- Ambiguity ----
# Documents uncertain or disputed text passages.

:Ambiguity
    a owl:Class ;
    rdfs:label "Ambiguity" ;
    rdfs:comment "An uncertain or disputed passage in statutory text, with alternative interpretations and (if known) the resolving authority." .

# ---- RelatedProvision ----
# Cross-document semantic relationships.

:RelatedProvision
    a owl:Class ;
    rdfs:label "RelatedProvision" ;
    rdfs:comment "A relationship between two statutory provisions (dependency, conflict, implementation, exception, etc.)." .

# ============================================================
# NormativeExtraction Properties
# ============================================================

:extractionId
    a owl:DatatypeProperty ;
    rdfs:domain :NormativeExtraction ;
    rdfs:range xsd:anyURI ;
    rdfs:label "extractionId" ;
    rdfs:comment "Canonical URI: urn:uslm:extraction:{source-provision}:{interpretation-id}:{version}." .

# :sourceProvision, :sourceText, :sourceOffsets reused from
# ufo-l.ttl and legalruleml.ttl without redefinition.

:sourceDocument
    a owl:ObjectProperty ;
    rdfs:domain :NormativeExtraction ;
    rdfs:range :DocumentNode ;
    rdfs:label "sourceDocument" ;
    rdfs:comment "The DocumentNode in the legislative hierarchy from which this extraction originates." .

:extractionDate
    a owl:DatatypeProperty ;
    rdfs:domain :NormativeExtraction ;
    rdfs:range xsd:dateTime ;
    rdfs:label "extractionDate" ;
    rdfs:comment "Timestamp when the parser produced this extraction." .

:modelVersion
    a owl:DatatypeProperty ;
    rdfs:domain :NormativeExtraction ;
    rdfs:range xsd:string ;
    rdfs:label "modelVersion" ;
    rdfs:comment "Identifier of the parsing model version that produced this extraction (e.g., 'claude-4.5')." .

:confidenceScore
    a owl:DatatypeProperty ;
    rdfs:domain :NormativeExtraction ;
    rdfs:range xsd:decimal ;
    rdfs:label "confidenceScore" ;
    rdfs:comment "Model confidence in this extraction, range 0.0–1.0. See ontology-schema.md §Step 11 for the scoring rubric." .

:normativeStatements
    a owl:ObjectProperty ;
    rdfs:domain :NormativeExtraction ;
    rdfs:range :NormativeStatement ;
    rdfs:label "normativeStatements" ;
    rdfs:comment "All PrescriptiveStatement, ConstitutiveStatement, and PenaltyStatement objects in this provision (multivalued)." .

:createdPositions
    a owl:ObjectProperty ;
    rdfs:domain :NormativeExtraction ;
    rdfs:range :LegalRelator ;
    rdfs:label "createdPositions" ;
    rdfs:comment "All Hohfeldian legal positions this provision creates (multivalued)." .

:modifiedPositions
    a owl:DatatypeProperty ;
    rdfs:domain :NormativeExtraction ;
    rdfs:range xsd:anyURI ;
    rdfs:label "modifiedPositions" ;
    rdfs:comment "URIs of existing LegalRelators that this provision modifies (multivalued)." .

:extinguishedPositions
    a owl:DatatypeProperty ;
    rdfs:domain :NormativeExtraction ;
    rdfs:range xsd:anyURI ;
    rdfs:label "extinguishedPositions" ;
    rdfs:comment "URIs of LegalRelators that cease to have effect due to this provision (multivalued)." .

:domainEntities
    a owl:ObjectProperty ;
    rdfs:domain :NormativeExtraction ;
    rdfs:range :DomainEntity ;
    rdfs:label "domainEntities" ;
    rdfs:comment "Real-world domain entities this provision concerns (multivalued)." .

:usedDefinitions
    a owl:ObjectProperty ;
    rdfs:domain :NormativeExtraction ;
    rdfs:range :DefinedTerm ;
    rdfs:label "usedDefinitions" ;
    rdfs:comment "Statutory DefinedTerm objects that govern interpretation of this provision (multivalued)." .

:relatedProvisions
    a owl:ObjectProperty ;
    rdfs:domain :NormativeExtraction ;
    rdfs:range :RelatedProvision ;
    rdfs:label "relatedProvisions" ;
    rdfs:comment "Other provisions this one depends on, modifies, or is semantically related to (multivalued)." .

:overridingRules
    a owl:ObjectProperty ;
    rdfs:domain :NormativeExtraction ;
    rdfs:range :OverridingRule ;
    rdfs:label "overridingRules" ;
    rdfs:comment "Override relationships (lex specialis, lex posterior, etc.) applicable to this extraction (multivalued)." .

:interpretations
    a owl:ObjectProperty ;
    rdfs:domain :NormativeExtraction ;
    rdfs:range :JudicialInterpretation ;
    rdfs:label "interpretations" ;
    rdfs:comment "Court decisions that have interpreted this provision (multivalued)." .

:currentValidInterpretation
    a owl:DatatypeProperty ;
    rdfs:domain :NormativeExtraction ;
    rdfs:range xsd:anyURI ;
    rdfs:label "currentValidInterpretation" ;
    rdfs:comment "URI of the NormativeExtraction version that is currently authoritative." .

:temporalScope
    a owl:DatatypeProperty ;
    rdfs:domain :NormativeExtraction ;
    rdfs:range xsd:duration ;
    rdfs:label "temporalScope" ;
    rdfs:comment "Duration over which this provision applies (e.g., 'P5Y' = 5 years)." .

:ambiguities
    a owl:ObjectProperty ;
    rdfs:domain :NormativeExtraction ;
    rdfs:range :Ambiguity ;
    rdfs:label "ambiguities" ;
    rdfs:comment "Identified ambiguous passages and their possible interpretations (multivalued)." .

:parsingNotes
    a owl:DatatypeProperty ;
    rdfs:domain :NormativeExtraction ;
    rdfs:range xsd:string ;
    rdfs:label "parsingNotes" ;
    rdfs:comment "Parsing model's notes on difficult, ambiguous, or contested aspects of this provision." .

:requiresHumanReview
    a owl:DatatypeProperty ;
    rdfs:domain :NormativeExtraction ;
    rdfs:range xsd:boolean ;
    rdfs:label "requiresHumanReview" ;
    rdfs:comment "True if a human expert should verify this extraction (e.g., low confidence, circuit splits, recent amendment)." .

# ============================================================
# JudicialInterpretation Properties
# ============================================================

:interpretationId
    a owl:DatatypeProperty ;
    rdfs:domain :JudicialInterpretation ;
    rdfs:range xsd:anyURI ;
    rdfs:label "interpretationId" ;
    rdfs:comment "Canonical URI: urn:uslm:interpretation:case:{case-identifier}." .

:caseName
    a owl:DatatypeProperty ;
    rdfs:domain :JudicialInterpretation ;
    rdfs:range xsd:string ;
    rdfs:label "caseName" ;
    rdfs:comment "Full case name (e.g., 'Monell v. Department of Social Services')." .

:courtName
    a owl:DatatypeProperty ;
    rdfs:domain :JudicialInterpretation ;
    rdfs:range xsd:string ;
    rdfs:label "courtName" ;
    rdfs:comment "Name of the deciding court." .

:courtLevel
    a owl:DatatypeProperty ;
    rdfs:domain :JudicialInterpretation ;
    rdfs:range xsd:string ;
    rdfs:label "courtLevel" ;
    rdfs:comment "One of: DistrictCourt, CircuitCourt, SupremeCourt, State, Other." .

:decisionDate
    a owl:DatatypeProperty ;
    rdfs:domain :JudicialInterpretation ;
    rdfs:range xsd:dateTime ;
    rdfs:label "decisionDate" ;
    rdfs:comment "Date the decision was handed down." .

:caseNumber
    a owl:DatatypeProperty ;
    rdfs:domain :JudicialInterpretation ;
    rdfs:range xsd:string ;
    rdfs:label "caseNumber" ;
    rdfs:comment "Official case number (e.g., 'No. 76-1495')." .

:publicationCitation
    a owl:DatatypeProperty ;
    rdfs:domain :JudicialInterpretation ;
    rdfs:range xsd:string ;
    rdfs:label "publicationCitation" ;
    rdfs:comment "Published citation (e.g., '436 U.S. 658', '42 F.3d 123')." .

:interpretedProvision
    a owl:DatatypeProperty ;
    rdfs:domain :JudicialInterpretation ;
    rdfs:range xsd:anyURI ;
    rdfs:label "interpretedProvision" ;
    rdfs:comment "URI of the statute or provision this decision interprets." .

:holding
    a owl:DatatypeProperty ;
    rdfs:domain :JudicialInterpretation ;
    rdfs:range xsd:string ;
    rdfs:label "holding" ;
    rdfs:comment "The legal holding: what the court decided and its doctrinal significance." .

:interpretsAsCreatingPositions
    a owl:ObjectProperty ;
    rdfs:domain :JudicialInterpretation ;
    rdfs:range :LegalRelator ;
    rdfs:label "interpretsAsCreatingPositions" ;
    rdfs:comment "LegalRelators the court's interpretation creates beyond the plain statutory text (multivalued)." .

:interpretsAsProhibiting
    a owl:DatatypeProperty ;
    rdfs:domain :JudicialInterpretation ;
    rdfs:range xsd:string ;
    rdfs:label "interpretsAsProhibiting" ;
    rdfs:comment "What the court says the statute prohibits, in natural language (multivalued)." .

:overridesStatutoryText
    a owl:DatatypeProperty ;
    rdfs:domain :JudicialInterpretation ;
    rdfs:range xsd:boolean ;
    rdfs:label "overridesStatutoryText" ;
    rdfs:comment "True if this interpretation departs from or supplements the statute's plain text." .

:ifSoOverrides
    a owl:ObjectProperty ;
    rdfs:domain :JudicialInterpretation ;
    rdfs:range :NormativeStatement ;
    rdfs:label "ifSoOverrides" ;
    rdfs:comment "Which NormativeStatements this interpretation overrides (multivalued; only if overridesStatutoryText = true)." .

:interpretationAuthority
    a owl:DatatypeProperty ;
    rdfs:domain :JudicialInterpretation ;
    rdfs:range xsd:string ;
    rdfs:label "interpretationAuthority" ;
    rdfs:comment "One of: SupremeLawOfLand, BindingPrecedent, PersuasivePrecedent." .

:interpretationJurisdiction
    a owl:DatatypeProperty ;
    rdfs:domain :JudicialInterpretation ;
    rdfs:range xsd:string ;
    rdfs:label "interpretationJurisdiction" ;
    rdfs:comment "Geographic/circuit scope of this decision's binding effect." .

:dissent
    a owl:DatatypeProperty ;
    rdfs:domain :JudicialInterpretation ;
    rdfs:range xsd:string ;
    rdfs:label "dissent" ;
    rdfs:comment "Summary of the dissenting opinion's position, if any." .

:retroactiveEffect
    a owl:DatatypeProperty ;
    rdfs:domain :JudicialInterpretation ;
    rdfs:range xsd:boolean ;
    rdfs:label "retroactiveEffect" ;
    rdfs:comment "True if this interpretation may be applied retroactively to past conduct." .

:relatedDecisions
    a owl:DatatypeProperty ;
    rdfs:domain :JudicialInterpretation ;
    rdfs:range xsd:anyURI ;
    rdfs:label "relatedDecisions" ;
    rdfs:comment "URIs of other judicial interpretations that cite or follow this one (multivalued)." .

# ============================================================
# CanonicalAgent Properties
# ============================================================

:canonicalId
    a owl:DatatypeProperty ;
    rdfs:domain :CanonicalAgent ;
    rdfs:range xsd:anyURI ;
    rdfs:label "canonicalId" ;
    rdfs:comment "The single canonical IRI representing this agent, used everywhere in the knowledge graph." .

:primaryLabel
    a owl:DatatypeProperty ;
    rdfs:domain :CanonicalAgent ;
    rdfs:range xsd:string ;
    rdfs:label "primaryLabel" ;
    rdfs:comment "The authoritative name for this agent (e.g., 'EPA Administrator')." .

:canonicalAliases
    a owl:DatatypeProperty ;
    rdfs:domain :CanonicalAgent ;
    rdfs:range xsd:string ;
    rdfs:label "canonicalAliases" ;
    rdfs:comment "All names by which this agent is known across statutes (multivalued)." .

:canonicalAgentType
    a owl:DatatypeProperty ;
    rdfs:domain :CanonicalAgent ;
    rdfs:range xsd:string ;
    rdfs:label "canonicalAgentType" ;
    rdfs:comment "One of: Person, Organization, GovernmentOffice, Role, Other." .

:createdByStatute
    a owl:DatatypeProperty ;
    rdfs:domain :CanonicalAgent ;
    rdfs:range xsd:anyURI ;
    rdfs:label "createdByStatute" ;
    rdfs:comment "URI of the statute that created this office or position (for government entities)." .

:canonicalJurisdiction
    a owl:DatatypeProperty ;
    rdfs:domain :CanonicalAgent ;
    rdfs:range xsd:anyURI ;
    rdfs:label "canonicalJurisdiction" ;
    rdfs:comment "URI of the jurisdiction in which this agent operates." .

:parentOrganization
    a owl:ObjectProperty ;
    rdfs:domain :CanonicalAgent ;
    rdfs:range :CanonicalAgent ;
    rdfs:label "parentOrganization" ;
    rdfs:comment "The superior organization or office (e.g., EPA Administrator's parent is EPA)." .

:isLegalRole
    a owl:DatatypeProperty ;
    rdfs:domain :CanonicalAgent ;
    rdfs:range xsd:boolean ;
    rdfs:label "isLegalRole" ;
    rdfs:comment "True if this represents a position/role rather than a specific individual." .

:roleDescription
    a owl:DatatypeProperty ;
    rdfs:domain :CanonicalAgent ;
    rdfs:range xsd:string ;
    rdfs:label "roleDescription" ;
    rdfs:comment "Description of the role and its legal significance." .

:creationDate
    a owl:DatatypeProperty ;
    rdfs:domain :CanonicalAgent ;
    rdfs:range xsd:dateTime ;
    rdfs:label "creationDate" ;
    rdfs:comment "Date this office or role was created by statute." .

:dissolutionDate
    a owl:DatatypeProperty ;
    rdfs:domain :CanonicalAgent ;
    rdfs:range xsd:dateTime ;
    rdfs:label "dissolutionDate" ;
    rdfs:comment "Date this office or role was abolished or ceased to exist." .

:equivalentAgents
    a owl:DatatypeProperty ;
    rdfs:domain :CanonicalAgent ;
    rdfs:range xsd:anyURI ;
    rdfs:label "equivalentAgents" ;
    rdfs:comment "Canonical IRIs of agents considered legally equivalent for certain purposes (multivalued)." .

:subordinateAgents
    a owl:DatatypeProperty ;
    rdfs:domain :CanonicalAgent ;
    rdfs:range xsd:anyURI ;
    rdfs:label "subordinateAgents" ;
    rdfs:comment "Canonical IRIs of agents under this agent's authority (multivalued)." .

# ============================================================
# AliasResolutionRule Properties
# ============================================================

:aliasPattern
    a owl:DatatypeProperty ;
    rdfs:domain :AliasResolutionRule ;
    rdfs:range xsd:string ;
    rdfs:label "aliasPattern" ;
    rdfs:comment "Regex or pattern string for matching the alias (e.g., 'the Secretary' preceded by 'Labor')." .

:contextRequirements
    a owl:DatatypeProperty ;
    rdfs:domain :AliasResolutionRule ;
    rdfs:range xsd:string ;
    rdfs:label "contextRequirements" ;
    rdfs:comment "Context needed to apply this resolution (e.g., 'within Chapter 21 — Labor')." .

:resolvesTo
    a owl:ObjectProperty ;
    rdfs:domain :AliasResolutionRule ;
    rdfs:range :CanonicalAgent ;
    rdfs:label "resolvesTo" ;
    rdfs:comment "The CanonicalAgent this alias pattern resolves to." .

:resolutionConfidence
    a owl:DatatypeProperty ;
    rdfs:domain :AliasResolutionRule ;
    rdfs:range xsd:decimal ;
    rdfs:label "resolutionConfidence" ;
    rdfs:comment "Confidence in this resolution (0.0–1.0)." .

:counterExamples
    a owl:DatatypeProperty ;
    rdfs:domain :AliasResolutionRule ;
    rdfs:range xsd:string ;
    rdfs:label "counterExamples" ;
    rdfs:comment "Known cases where this alias pattern does NOT resolve to the target agent (multivalued)." .

# ============================================================
# AuthoritativeInterpretation Properties
# ============================================================

:authInterpProvision
    a owl:DatatypeProperty ;
    rdfs:domain :AuthoritativeInterpretation ;
    rdfs:range xsd:anyURI ;
    rdfs:label "authInterpProvision" ;
    rdfs:comment "URI of the statutory provision whose authoritative interpretation this describes." .

:applicableJurisdiction
    a owl:DatatypeProperty ;
    rdfs:domain :AuthoritativeInterpretation ;
    rdfs:range xsd:anyURI ;
    rdfs:label "applicableJurisdiction" ;
    rdfs:comment "URI of the jurisdiction where this interpretation is binding." .

:authorityHierarchy
    a owl:DatatypeProperty ;
    rdfs:domain :AuthoritativeInterpretation ;
    rdfs:range xsd:integer ;
    rdfs:label "authorityHierarchy" ;
    rdfs:comment "Numeric authority level: 1 = SCOTUS, 2 = Circuit, 3 = District, 4 = Non-binding." .

:controllingDecision
    a owl:ObjectProperty ;
    rdfs:domain :AuthoritativeInterpretation ;
    rdfs:range :JudicialInterpretation ;
    rdfs:label "controllingDecision" ;
    rdfs:comment "The JudicialInterpretation that establishes this interpretation as authoritative." .

:validAsOf
    a owl:DatatypeProperty ;
    rdfs:domain :AuthoritativeInterpretation ;
    rdfs:range xsd:dateTime ;
    rdfs:label "validAsOf" ;
    rdfs:comment "The date from which this interpretation is controlling." .

:overriddenByDecision
    a owl:ObjectProperty ;
    rdfs:domain :AuthoritativeInterpretation ;
    rdfs:range :JudicialInterpretation ;
    rdfs:label "overriddenByDecision" ;
    rdfs:comment "A later JudicialInterpretation that superseded this one, if any." .

:authInterpNotes
    a owl:DatatypeProperty ;
    rdfs:domain :AuthoritativeInterpretation ;
    rdfs:range xsd:string ;
    rdfs:label "authInterpNotes" ;
    rdfs:comment "Explanatory notes about the scope or limitations of this controlling interpretation." .

# ============================================================
# Ambiguity Properties
# ============================================================

:ambiguityId
    a owl:DatatypeProperty ;
    rdfs:domain :Ambiguity ;
    rdfs:range xsd:anyURI ;
    rdfs:label "ambiguityId" ;
    rdfs:comment "Canonical URI for this ambiguity instance." .

:ambiguityType
    a owl:DatatypeProperty ;
    rdfs:domain :Ambiguity ;
    rdfs:range xsd:string ;
    rdfs:label "ambiguityType" ;
    rdfs:comment "One of: Syntactic, Semantic, ReferentialAmbiguity, TemporalAmbiguity, ScopeAmbiguity." .

:ambiguousText
    a owl:DatatypeProperty ;
    rdfs:domain :Ambiguity ;
    rdfs:range xsd:string ;
    rdfs:label "ambiguousText" ;
    rdfs:comment "The verbatim text passage that is ambiguous." .

:possibleInterpretations
    a owl:DatatypeProperty ;
    rdfs:domain :Ambiguity ;
    rdfs:range xsd:string ;
    rdfs:label "possibleInterpretations" ;
    rdfs:comment "Alternative readings of the ambiguous passage (multivalued, at least 2)." .

:resolvingAuthority
    a owl:DatatypeProperty ;
    rdfs:domain :Ambiguity ;
    rdfs:range xsd:anyURI ;
    rdfs:label "resolvingAuthority" ;
    rdfs:comment "URI of the court decision or regulation that resolves this ambiguity, if known." .

:selectedInterpretation
    a owl:DatatypeProperty ;
    rdfs:domain :Ambiguity ;
    rdfs:range xsd:string ;
    rdfs:label "selectedInterpretation" ;
    rdfs:comment "The interpretation the parser adopted, with a brief rationale." .

# ============================================================
# RelatedProvision Properties
# ============================================================

:relatedProvisionUri
    a owl:DatatypeProperty ;
    rdfs:domain :RelatedProvision ;
    rdfs:range xsd:anyURI ;
    rdfs:label "relatedProvisionUri" ;
    rdfs:comment "URI of the related statutory provision." .

:relationshipType
    a owl:DatatypeProperty ;
    rdfs:domain :RelatedProvision ;
    rdfs:range xsd:string ;
    rdfs:label "relationshipType" ;
    rdfs:comment "One of: ModifiesOrAmends, DependsOn, ConflictsWith, ImplementedBy, AppliedBy, DefinedBy, ExceptedBy." .

:relatedDescription
    a owl:DatatypeProperty ;
    rdfs:domain :RelatedProvision ;
    rdfs:range xsd:string ;
    rdfs:label "relatedDescription" ;
    rdfs:comment "Brief natural language description of the relationship." .

:semanticJustification
    a owl:DatatypeProperty ;
    rdfs:domain :RelatedProvision ;
    rdfs:range xsd:string ;
    rdfs:label "semanticJustification" ;
    rdfs:comment "Why these two provisions are related — the legal or semantic rationale." .
